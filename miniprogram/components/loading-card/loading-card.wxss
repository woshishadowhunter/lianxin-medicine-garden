.loading-cards {
  margin-bottom: 24rpx;
}

.loading-card {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: var(--radius);
  background: #fff;
  box-shadow: var(--shadow-soft);
}

.loading-avatar {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  border-radius: 16rpx;
}

.loading-lines {
  flex: 1;
}

.loading-line {
  height: 28rpx;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
}

.loading-line.short {
  width: 40%;
  margin-bottom: 0;
}

.skeleton {
  background: linear-gradient(90deg, #edf2ed 25%, #f6f8f4 50%, #edf2ed 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
