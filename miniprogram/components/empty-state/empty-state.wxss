.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
}

.empty-text {
  text-align: center;
  font-size: 27rpx;
  line-height: 1.55;
  color: var(--text-hint);
}

.btn {
  min-height: 84rpx;
  padding: 0 42rpx;
  border: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.btn-primary {
  color: #fff;
  background: #123c2d;
  box-shadow: 0 12rpx 24rpx rgba(31, 107, 75, 0.22);
}

.mt-24 {
  margin-top: 24rpx;
}
