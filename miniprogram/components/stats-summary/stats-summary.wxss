.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0;
  overflow: hidden;
  margin-bottom: 24rpx;
  border-width: 1rpx 0;
  border-style: solid;
  border-color: var(--border);
  border-radius: 0;
  background: transparent;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 30rpx 8rpx 28rpx;
  border-right: 1rpx solid var(--border);
  text-align: center;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  margin-bottom: 8rpx;
  font-size: 40rpx;
  font-family: "Songti SC", "STSong", serif;
  font-weight: 700;
  line-height: 1;
}

.stat-label {
  font-size: 21rpx;
  line-height: 1.25;
  color: var(--text-muted);
}
