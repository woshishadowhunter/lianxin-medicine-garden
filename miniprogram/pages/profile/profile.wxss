.bind-section {
  padding-top: 70rpx;
}

.bind-header {
  margin-bottom: 44rpx;
  text-align: center;
}

.bind-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 20rpx;
  border-radius: 28rpx;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bind-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 46rpx;
  font-weight: 900;
}

.bind-subtitle {
  display: block;
  font-size: 27rpx;
  color: var(--text-muted);
}

.bind-form {
  padding: 32rpx 28rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.form-row:last-of-type {
  border-bottom: none;
}

.form-row-label {
  width: 168rpx;
  font-size: 27rpx;
  font-weight: 850;
  color: var(--text-secondary);
}

.form-input {
  flex: 1;
  font-size: 29rpx;
  color: var(--text-primary);
}

.profile-card {
  margin-bottom: 22rpx;
  padding: 34rpx 30rpx;
  border-radius: 16rpx;
  color: #fff;
  background: var(--primary-dark);
  box-shadow: var(--shadow);
}

.avatar {
  width: 94rpx;
  height: 94rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-name {
  display: block;
  margin-top: 26rpx;
  font-size: 42rpx;
  font-family: "Songti SC", "STSong", serif;
  font-weight: 700;
  line-height: 1.15;
  color: #fff;
}

.profile-community {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 10rpx;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.78);
}

.sync-card {
  display: grid;
  grid-template-columns: 68rpx 1fr auto;
  gap: 16rpx;
  align-items: center;
  padding: 22rpx;
  background: var(--info-light);
  border-color: rgba(61, 115, 156, 0.16);
}

.points-entry {
  display: grid;
  grid-template-columns: 62rpx 1fr auto 24rpx;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 22rpx;
  padding: 24rpx 22rpx;
  border: 1rpx solid rgba(185, 139, 69, .28);
  border-radius: var(--radius);
  background: var(--accent-light);
}

.points-entry-mark { width: 62rpx; height: 62rpx; display: flex; align-items: center; justify-content: center; border-radius: 16rpx; background: rgba(185, 139, 69, .12); }
.points-entry-copy text { display: block; font-size: 28rpx; font-weight: 800; }
.points-entry-copy view { margin-top: 6rpx; color: var(--text-muted); font-size: 22rpx; }
.points-entry-balance { min-width: 80rpx; text-align: right; }
.points-entry-balance text { display: block; color: var(--primary-dark); font-family: "Songti SC", "STSong", serif; font-size: 38rpx; font-weight: 700; }
.points-entry-balance view { margin-top: 3rpx; color: var(--text-muted); font-size: 20rpx; }

.sync-icon,
.menu-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 16rpx;
  background: rgba(31, 107, 75, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.sync-title,
.menu-title {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
  color: var(--text-primary);
}

.sync-count,
.menu-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.4;
  color: var(--text-muted);
}

.sync-action,
.menu-action {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 850;
}

.menu-list {
  display: grid;
  gap: 0;
  padding: 0 22rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-card);
}

.menu-item {
  display: grid;
  grid-template-columns: 62rpx 1fr auto;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 0;
  padding: 24rpx 0;
  border-width: 0 0 1rpx;
  border-radius: 0;
  background: transparent;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-copy {
  min-width: 0;
}

.menu-icon.accent {
  background: var(--accent-light);
}

.menu-icon.muted {
  background: var(--surface-2);
}
