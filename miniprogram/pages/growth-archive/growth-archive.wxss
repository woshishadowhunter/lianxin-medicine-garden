.archive-card {
  margin-bottom: 22rpx;
}

.archive-card:active {
  transform: translateY(1rpx);
  opacity: 0.9;
}

.archive-icon {
  width: 82rpx;
  height: 82rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
  border-radius: 16rpx;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.archive-name {
  font-size: 34rpx;
  font-weight: 800;
}

.archive-date {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

.archive-status {
  flex-shrink: 0;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  font-size: 23rpx;
  font-weight: 700;
}

.growth-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.growth-info {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--primary);
}

.growth-bar {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: var(--border);
}

.growth-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--primary);
  transition: width 0.5s;
}

.harvest-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.archive-stats {
  flex-wrap: wrap;
  padding: 18rpx 0 2rpx;
  border-top: 1rpx solid var(--divider);
}

.archive-stat {
  width: 25%;
  margin-bottom: 14rpx;
  text-align: center;
}

.archive-stat-val {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.15;
}

.archive-stat-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--text-hint);
}

.type-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  font-size: 20rpx;
  font-weight: 700;
  color: var(--primary);
}
