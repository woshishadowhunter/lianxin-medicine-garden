.garden-actions {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.add-plant-action,
.archive-link {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 14rpx;
}

.add-plant-action {
  flex: 1;
  padding: 18rpx 22rpx;
  color: #fff;
  background: var(--primary-dark);
}

.add-plant-action text { display: block; font-size: 28rpx; font-weight: 850; }
.add-plant-action view view { margin-top: 4rpx; color: rgba(255,255,255,.72); font-size: 21rpx; }
.archive-link { flex: 0 0 176rpx; justify-content: center; flex-direction: column; border: 1rpx solid var(--border); color: var(--primary); background: var(--bg-card); font-size: 23rpx; font-weight: 750; }

.garden-category-scroll { width: 100%; margin: 10rpx 0 8rpx; white-space: nowrap; }
.garden-category-row { display: inline-flex; gap: 12rpx; padding-right: 20rpx; }
.filter-chip { min-height: 64rpx; padding: 0 24rpx; display: inline-flex; align-items: center; border: 1rpx solid var(--border); border-radius: 8rpx; color: var(--text-secondary); background: var(--bg-card); font-size: 23rpx; font-weight: 700; }
.filter-chip.active { color: #fff; border-color: var(--primary); background: var(--primary); }

.summary-bar {
  padding: 0;
  border-width: 1rpx 0;
  border-radius: 0;
  background: transparent;
}

.summary-item {
  flex: 1;
  padding: 24rpx 8rpx 22rpx;
  border-right: 1rpx solid var(--border);
  text-align: center;
}

.summary-item:last-child {
  border-right: none;
}

.summary-num {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.1;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.herb-task {
  margin-bottom: 0;
  padding: 26rpx 0;
  border-width: 0 0 1rpx;
  border-radius: 0;
  background: transparent;
}

.task-top {
  display: grid;
  grid-template-columns: 76rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
}

.task-copy {
  min-width: 0;
}

.herb-card-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-cover { width: 100%; height: 100%; border-radius: 16rpx; }

.herb-card-name {
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
  color: var(--text-primary);
}

.plant-category-label { display: inline-flex; margin-top: 6rpx; padding: 3rpx 10rpx; border-radius: 999rpx; color: var(--primary); background: var(--primary-soft); font-size: 20rpx; font-weight: 750; }

.herb-card-date {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--text-muted);
}

.herb-status-badge {
  flex-shrink: 0;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: var(--bg);
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 21rpx;
  font-weight: 850;
}

.status-growing {
  color: var(--primary);
  background: var(--primary-soft);
}

.status-warning {
  color: #8a4d00;
  background: var(--warning-light);
}

.status-dead {
  color: var(--danger);
  background: var(--danger-light);
}

.status-harvested {
  color: var(--info);
  background: var(--info-light);
}

.growth-info {
  font-size: 23rpx;
  color: var(--text-muted);
}

.growth-bar {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: var(--border);
}

.growth-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--primary);
  transition: width 0.5s ease;
}

.companion-days { margin-top: 18rpx; padding-top: 16rpx; border-top: 1rpx solid var(--border); color: var(--text-muted); font-size: 23rpx; line-height: 1.5; }
