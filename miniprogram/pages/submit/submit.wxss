.submit-page {
  padding-bottom: 70rpx;
}

.offline-banner,
.pending-banner {
  margin-bottom: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.offline-banner {
  color: #8c5410;
  background: var(--warning-light);
  border: 1rpx solid rgba(216, 146, 47, 0.18);
}

.pending-banner {
  color: var(--info);
  background: var(--info-light);
  border: 1rpx solid rgba(61, 115, 156, 0.16);
}

.steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  margin-bottom: 26rpx;
  border-bottom: 1rpx solid var(--border);
}

.step {
  height: 64rpx;
  border: none;
  border-bottom: 4rpx solid transparent;
  border-radius: 0;
  background: transparent;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 850;
}

.step.active {
  color: var(--primary-dark);
  border-bottom-color: var(--primary-dark);
  background: transparent;
}

.step.done {
  color: var(--primary);
  background: transparent;
}

.herb-select-item,
.selected-context {
  display: grid;
  grid-template-columns: 76rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 0;
  padding: 24rpx 0;
  border-width: 0 0 1rpx;
  border-radius: 0;
  background: transparent;
}

.herb-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}

.herb-cover { width: 100%; height: 100%; border-radius: 16rpx; }

.herb-icon.small {
  width: 64rpx;
  height: 64rpx;
}

.herb-name {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.herb-date {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--text-muted);
}

.change-link {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 850;
}

.photo-hint {
  margin: -6rpx 0 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-muted);
}

.photo-upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.photo-preview-wrap {
  position: relative;
  width: calc(33.33% - 10rpx);
}

.photo-preview {
  width: 100%;
  height: 204rpx;
  border-radius: var(--radius);
  background: var(--bg-deep);
}

.photo-delete,
.photo-check {
  position: absolute;
  top: -8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.photo-delete {
  right: -8rpx;
  background: var(--danger);
}

.photo-check {
  left: -8rpx;
  background: var(--primary);
}

.photo-add-btn {
  width: calc(66.66% - 5rpx);
  height: 204rpx;
  border: 2rpx dashed rgba(31, 107, 75, 0.32);
  border-radius: var(--radius);
  color: var(--primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(229, 240, 233, 0.72);
}

.add-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 850;
  color: var(--primary);
}

.add-count {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.selected-summary {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  font-size: 25rpx;
  font-weight: 850;
  color: var(--primary);
  background: var(--primary-soft);
}

.summary-divider {
  color: rgba(31, 107, 75, 0.24);
}

.form-item {
  margin-bottom: 16rpx;
}

.form-label {
  margin-bottom: 14rpx;
  font-size: 25rpx;
  font-weight: 850;
  color: var(--text-secondary);
}

.form-value {
  min-height: 48rpx;
  padding: 6rpx 0;
  font-size: 29rpx;
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 190rpx;
  padding: 10rpx 0 0;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.char-count {
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-hint);
}

.progress-bar-wrap {
  height: 12rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  background: var(--border);
}

.progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--primary);
  transition: width 0.3s;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
}

.offline-notice {
  padding: 18rpx 22rpx;
  border-radius: var(--radius);
  background: var(--warning-light);
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #8c5410;
}

.back-btn {
  padding: 26rpx 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 27rpx;
  font-weight: 850;
  color: var(--text-muted);
}

.bind-guide {
  margin-top: 40rpx;
  padding: 64rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  text-align: center;
}

.bind-guide-title {
  font-size: 31rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.bind-guide-desc {
  font-size: 25rpx;
  color: var(--text-muted);
  line-height: 1.6;
  max-width: 440rpx;
}
