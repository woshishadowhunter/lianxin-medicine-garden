<view class="container">
  <view wx:if="{{loading}}" class="load-more">加载中...</view>

  <block wx:elif="{{task}}">
    <!-- 植物信息 -->
    <view class="herb-info card">
      <view class="flex-row">
        <view class="herb-info-icon">
          <image wx:if="{{task.cover_image}}" src="{{task.cover_image}}" mode="aspectFill" class="detail-cover"></image>
          <lx-icon wx:else name="{{task.plant_icon_name || 'garden'}}" size="{{52}}" tone="brand" />
        </view>
        <view class="flex-1">
          <view class="herb-info-name">{{task.plant_name}}</view>
          <view class="plant-detail-meta">{{task.categoryLabel}} · {{task.sourceLabel}}</view>
          <view class="herb-info-date">种植日期：{{task.plant_date}}</view>
          <view class="herb-info-status">已陪伴 {{task.elapsedDays}} 天</view>
        </view>
      </view>
    </view>

    <!-- 养护时间轴 -->
    <view class="card-title">养护时间轴</view>
    <view wx:if="{{!records.length}}" class="empty-state">
      <view class="empty-icon">
        <lx-icon name="record" size="{{72}}" tone="brand" />
      </view>
      <text class="empty-text">暂无养护记录</text>
    </view>

    <view wx:else class="timeline">
      <view wx:for="{{records}}" wx:key="_id" class="timeline-item">
        <view class="timeline-line"><view class="timeline-dot"></view></view>
        <view class="timeline-card card">
          <view class="flex-between">
            <view class="flex-row">
              <view class="record-type-icon">
                <lx-icon name="{{item.typeIconName}}" size="{{34}}" tone="brand" />
              </view>
              <view>
                <view class="record-date">{{item.care_date}} {{item.care_time || ''}}</view>
                <view class="record-type">{{item.care_type_label || item.care_type}}</view>
              </view>
            </view>
            <view class="tag tag-{{item.audit_status}}">
              {{item.audit_status === 'pending' ? '待审核' : item.audit_status === 'confirmed' ? '已确认' : '需修正'}}
            </view>
          </view>
          <view wx:if="{{item.photos && item.photos.length}}" class="photo-row mt-16">
            <image wx:for="{{item.photos}}" wx:for-item="pic" wx:key="*this" src="{{pic}}" mode="aspectFill" class="timeline-photo" wx:if="{{index < 3}}"></image>
          </view>
          <view wx:if="{{item.description}}" class="record-desc mt-8">{{item.description}}</view>
        </view>
      </view>
    </view>

    <view class="bottom-action mt-24">
      <button class="btn btn-primary" bindtap="goAddRecord">新增养护记录</button>
    </view>
  </block>
</view>
