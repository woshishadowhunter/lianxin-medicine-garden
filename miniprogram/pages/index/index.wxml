<view class="container">
  <!-- 登录引导 -->
  <block wx:if="{{!familyCode && !loading}}">
    <view class="login-guide">
      <view class="brand-mark">
        <lx-icon name="herb" size="{{58}}" tone="white" />
      </view>
      <text class="brand-title">连心植物园</text>
      <text class="guide-desc">绑定家庭账号，记录花草蔬果的每一次生长。</text>
      <button class="btn btn-primary guide-action" bindtap="goBind" hover-class="tap-card">绑定家庭账号</button>
    </view>
  </block>

  <block wx:elif="{{loading}}">
    <loading-card rows="{{3}}" showAvatar="{{false}}" />
  </block>

  <!-- 首页内容 -->
  <block wx:elif="{{familyCode}}">
    <view class="journal-masthead">
      <view class="brand-row">
        <view class="brand-copy">
          <text class="journal-label">家庭植物观察簿</text>
          <text class="home-title">连心植物园</text>
          <text class="home-subtitle">{{familyInfo.community || '社区信息待完善'}} · 家庭 {{familyInfo.family_code || familyCode}}</text>
        </view>
        <view class="points-stamp" bindtap="navigateTo" data-url="/pages/points/points" hover-class="tap-chip">
          <text>{{pointsBalance}}</text>
          <view>积分</view>
        </view>
      </view>
    </view>

    <view wx:if="{{featuredStory}}" class="story-feature" bindtap="navigateTo" data-url="/pages/records/records" hover-class="tap-card">
      <image src="{{featuredStory.photo}}" mode="aspectFill"></image>
      <view class="story-caption">
        <view><text>{{featuredStory.plantName}}</text><text>{{featuredStory.date}}</text></view>
        <text class="story-note">{{featuredStory.description}}</text>
      </view>
    </view>
    <view wx:else class="story-empty">
      <view><lx-icon name="camera" size="{{38}}" tone="brand" /></view>
      <text>第一张成长照片，会成为家庭观察簿的封面。</text>
    </view>

    <view class="primary-record-action" bindtap="navigateTo" data-url="/pages/submit/submit" hover-class="tap-card">
      <lx-icon name="camera" size="{{30}}" tone="white" />
      <view><text>拍照记录成长</text><text>上传照片，审核通过后获得积分</text></view>
      <lx-icon name="arrow-right" size="{{24}}" tone="white" />
    </view>

    <!-- 今日建议 -->
    <view wx:if="{{reminders.length}}">
      <view wx:for="{{reminders}}" wx:key="message" class="advice-panel panel">
        <view class="advice-icon {{item.urgent ? 'urgent' : ''}}">
          <lx-icon name="{{item.urgent ? 'warning' : 'water'}}" size="{{30}}" tone="{{item.urgent ? 'danger' : 'brand'}}" />
        </view>
        <view class="advice-copy">
          <text class="advice-title">{{item.urgent ? '需要尽快关注' : '建议及时查看'}}</text>
          <text class="advice-text">{{item.message}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="advice-panel panel">
      <view class="advice-icon">
        <lx-icon name="check" size="{{30}}" tone="brand" />
      </view>
      <view class="advice-copy">
        <text class="advice-title">养护节奏正常</text>
        <text class="advice-text">所有植物都在按时记录，继续保持当前观察节奏。</text>
      </view>
    </view>

    <stats-summary stats="{{stats}}" columns="{{4}}" />

    <view class="section-title">
      <text>近期养护日历</text>
      <text>过去 12 周</text>
    </view>
    <view class="section-card panel">
      <calendar-heatmap records="{{calendarRecords}}" />
    </view>

    <view wx:if="{{recentPhotos.length}}" class="section-title">
      <text>最近照片证据</text>
      <text bindtap="navigateTo" data-url="/pages/records/records" hover-class="tap-opacity">查看全部</text>
    </view>
    <view wx:if="{{recentPhotos.length}}" class="recent-photos">
      <view wx:for="{{recentPhotos}}" wx:key="photo" class="recent-photo" bindtap="navigateTo" data-url="/pages/records/records" hover-class="tap-card">
        <image src="{{item.photo}}" mode="aspectFill"></image>
        <text>{{item.plantName || '成长照片'}}</text>
      </view>
    </view>

    <view class="section-title">
      <text>常用入口</text>
      <text></text>
    </view>
    <view class="quick-actions">
      <view
        wx:for="{{quickActions}}" wx:key="label"
        class="action-item panel"
        bindtap="navigateTo" data-url="{{item.url}}"
        hover-class="tap-card"
      >
        <view class="action-icon">
          <lx-icon name="{{item.iconName}}" size="{{30}}" tone="brand" />
        </view>
        <text class="action-label">{{item.label}}</text>
      </view>
    </view>
  </block>
</view>
