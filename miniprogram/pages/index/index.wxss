.login-guide {
  min-height: calc(100vh - 160rpx);
  padding: 104rpx 34rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.brand-mark {
  width: 126rpx;
  height: 126rpx;
  margin-bottom: 28rpx;
  border-radius: 18rpx;
  background: var(--primary-dark);
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-title { display: block; margin-top: 10rpx; font-family: "Songti SC", "STSong", "SimSun", serif; font-size: 58rpx; font-weight: 700; line-height: 1.16; color: var(--text-primary); }
.guide-desc { display: block; max-width: 560rpx; margin-top: 22rpx; font-size: 28rpx; line-height: 1.7; color: var(--text-muted); }
.guide-action { width: 100%; margin-top: 44rpx; }

.journal-masthead { margin: -8rpx 0 22rpx; padding: 20rpx 2rpx 18rpx; border-bottom: 1rpx solid var(--border); }
.brand-row { display: flex; align-items: center; gap: 20rpx; }
.brand-copy { flex: 1; min-width: 0; }
.journal-label { display: block; margin-bottom: 6rpx; color: var(--text-muted); font-size: 21rpx; font-weight: 750; }
.home-title { display: block; font-family: "Songti SC", "STSong", "SimSun", serif; font-size: 54rpx; font-weight: 700; line-height: 1.12; color: var(--primary-dark); }
.home-subtitle { display: block; margin-top: 8rpx; font-size: 24rpx; line-height: 1.4; color: var(--text-secondary); }

.points-stamp { width: 92rpx; height: 92rpx; flex: 0 0 92rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 1rpx solid var(--accent); border-radius: 50%; color: var(--primary-dark); background: var(--accent-light); }
.points-stamp text { font-size: 29rpx; font-weight: 900; line-height: 1; }
.points-stamp view { margin-top: 5rpx; font-size: 19rpx; font-weight: 750; }

.story-feature { overflow: hidden; margin-bottom: 18rpx; border: 1rpx solid var(--border); border-radius: 10rpx; background: var(--bg-card); }
.story-feature > image { width: 100%; height: 370rpx; display: block; }
.story-caption { padding: 18rpx 20rpx 20rpx; }
.story-caption > view { display: flex; align-items: baseline; justify-content: space-between; gap: 18rpx; }
.story-caption > view text:first-child { overflow: hidden; font-family: "Songti SC", "STSong", "SimSun", serif; font-size: 32rpx; font-weight: 700; white-space: nowrap; text-overflow: ellipsis; }
.story-caption > view text:last-child { flex-shrink: 0; color: var(--text-muted); font-size: 22rpx; }
.story-note { display: block; margin-top: 8rpx; color: var(--text-secondary); font-size: 24rpx; line-height: 1.55; }

.story-empty { min-height: 236rpx; margin-bottom: 18rpx; padding: 36rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18rpx; border: 1rpx dashed var(--border); border-radius: 10rpx; color: var(--text-muted); background: var(--surface-2); text-align: center; line-height: 1.55; }
.story-empty > view { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: var(--primary-soft); }

.primary-record-action { min-height: 100rpx; margin-bottom: 28rpx; padding: 18rpx 22rpx; border-radius: 12rpx; color: #fff; background: var(--primary-dark); display: flex; align-items: center; gap: 16rpx; }
.primary-record-action > view { flex: 1; }
.primary-record-action > view text:first-child { display: block; font-size: 29rpx; font-weight: 850; }
.primary-record-action > view text:last-child { display: block; margin-top: 5rpx; color: rgba(255,255,255,.72); font-size: 21rpx; }

.advice-panel { display: grid; grid-template-columns: 72rpx 1fr; gap: 18rpx; align-items: center; margin-bottom: 0; padding: 24rpx 4rpx 26rpx; border-width: 0 0 1rpx; border-radius: 0; background: transparent; }
.advice-icon,
.action-icon { width: 64rpx; height: 64rpx; border-radius: 12rpx; background: var(--primary-soft); display: flex; align-items: center; justify-content: center; }
.advice-icon.urgent { background: var(--danger-light); }
.advice-title { display: block; font-size: 28rpx; font-weight: 800; color: var(--text-primary); }
.advice-text { display: block; margin-top: 8rpx; font-size: 24rpx; line-height: 1.55; color: var(--text-muted); }

.section-card { padding: 22rpx 20rpx; background: var(--bg-card); }
.recent-photos { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10rpx; margin-bottom: 24rpx; }
.recent-photo { position: relative; overflow: hidden; height: 154rpx; border-radius: 8rpx; background: var(--bg-deep); border: 1rpx solid var(--border); }
.recent-photo image { width: 100%; height: 100%; display: block; }
.recent-photo text { position: absolute; left: 8rpx; right: 8rpx; bottom: 8rpx; overflow: hidden; color: #fff; font-size: 19rpx; font-weight: 850; white-space: nowrap; text-overflow: ellipsis; text-shadow: 0 2rpx 8rpx rgba(0,0,0,.58); }

.quick-actions { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.action-item { flex: 1; min-height: 124rpx; margin-bottom: 0; padding: 18rpx 6rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10rpx; text-align: center; background: transparent; border-color: var(--border); }
.action-label { font-size: 23rpx; font-weight: 800; color: var(--text-secondary); }
