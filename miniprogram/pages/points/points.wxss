.points-page { min-height: 100vh; padding-bottom: 72rpx; background: var(--bg); }
.points-hero { position: relative; min-height: 288rpx; display: flex; align-items: flex-end; justify-content: space-between; gap: 24rpx; padding: 52rpx 34rpx 36rpx; color: #fff; background: #294f3d; }
.points-hero::after { content: ""; position: absolute; inset: auto 0 0; height: 8rpx; background: #e6b24a; }
.hero-copy { position: relative; z-index: 1; }
.points-bank-label { display: flex; align-items: center; gap: 10rpx; color: rgba(255,255,255,.78); font-size: 24rpx; }
.balance-line { display: flex; align-items: baseline; gap: 10rpx; margin-top: 22rpx; }
.points-balance { font-family: "Songti SC", "STSong", serif; font-size: 90rpx; font-weight: 700; line-height: 1; }
.points-unit { font-size: 25rpx; font-weight: 750; }
.hero-note { display: block; margin-top: 15rpx; color: rgba(255,255,255,.72); font-size: 23rpx; }
.account-seal { z-index: 1; flex: 0 0 116rpx; width: 116rpx; height: 116rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2rpx solid rgba(230,178,74,.72); border-radius: 50%; color: #f5d88a; }
.account-seal text { font-size: 25rpx; font-weight: 900; }
.account-seal view { margin-top: 6rpx; font-size: 18rpx; }
.points-content { padding-top: 0; }
.points-summary { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 24rpx; border-block: 1rpx solid var(--border); }
.points-summary > view { padding: 23rpx 8rpx; text-align: center; border-right: 1rpx solid var(--border); }
.points-summary > view:last-child { border-right: none; }
.points-summary text { display: block; color: var(--primary-dark); font-family: "Songti SC", "STSong", serif; font-size: 36rpx; font-weight: 700; }
.points-summary view view { margin-top: 6rpx; color: var(--text-muted); font-size: 21rpx; }
.view-tabs { display: grid; grid-template-columns: repeat(3, 1fr); margin: 28rpx 0 8rpx; border-bottom: 1rpx solid var(--border); }
.view-tab { position: relative; padding: 20rpx 6rpx; color: var(--text-muted); font-size: 25rpx; font-weight: 750; text-align: center; }
.view-tab.active { color: var(--primary-dark); }
.view-tab.active::after { content: ""; position: absolute; left: 24%; right: 24%; bottom: -1rpx; height: 5rpx; border-radius: 4rpx 4rpx 0 0; background: var(--accent); }
.section-heading { display: flex; align-items: center; justify-content: space-between; gap: 24rpx; padding: 30rpx 2rpx 18rpx; }
.section-heading > view text { display: block; }
.section-heading > view text:first-child { font-family: "Songti SC", "STSong", serif; font-size: 32rpx; font-weight: 700; color: var(--primary-dark); }
.section-heading > view text:last-child { margin-top: 7rpx; color: var(--text-muted); font-size: 21rpx; }
.section-heading > text { color: var(--text-muted); font-size: 22rpx; }
.reward-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.reward-card { min-width: 0; padding: 22rpx; border: 1rpx solid var(--border); border-radius: 12rpx; background: var(--bg-card); box-shadow: 0 8rpx 26rpx rgba(46,73,58,.06); }
.reward-visual { width: 82rpx; height: 82rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: var(--primary-soft); }
.reward-name { display: block; margin-top: 18rpx; font-size: 27rpx; font-weight: 850; }
.reward-desc { display: block; min-height: 65rpx; margin-top: 8rpx; color: var(--text-muted); font-size: 21rpx; line-height: 1.5; }
.reward-meta { display: flex; justify-content: space-between; gap: 10rpx; margin-top: 17rpx; font-size: 21rpx; }
.reward-meta text:first-child { color: var(--accent-dark); font-weight: 850; }
.reward-meta text:last-child { color: var(--text-hint); }
.redeem-button { width: 100%; height: 68rpx; display: flex; align-items: center; justify-content: center; margin-top: 15rpx; padding: 0 10rpx; border: none; border-radius: 8rpx; color: #fff; background: var(--primary); font-size: 23rpx; font-weight: 800; line-height: 1.2; }
.redeem-button[disabled] { color: var(--text-muted); background: var(--surface-2); opacity: 1; }
.redeem-button::after { border: none; }
.service-note { display: flex; align-items: flex-start; gap: 10rpx; margin-top: 20rpx; color: var(--text-muted); font-size: 21rpx; line-height: 1.55; }
.order-list { display: flex; flex-direction: column; gap: 18rpx; }
.order-card { padding: 24rpx; border: 1rpx solid var(--border); border-left: 6rpx solid var(--accent); border-radius: 10rpx; background: var(--bg-card); }
.order-top, .order-footer { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.order-name { display: block; font-size: 28rpx; font-weight: 850; }
.order-date { display: block; margin-top: 7rpx; color: var(--text-hint); font-size: 20rpx; }
.status-tag { flex-shrink: 0; padding: 7rpx 13rpx; border-radius: 6rpx; font-size: 21rpx; font-weight: 800; }
.status-tag.pending { color: #8c5c0b; background: #fff2cc; }
.status-tag.ready { color: #1f6450; background: #dcefe7; }
.status-tag.fulfilled { color: #3157a4; background: #e4ebfa; }
.status-tag.canceled { color: var(--text-muted); background: var(--surface-2); }
.order-detail { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-top: 22rpx; padding: 17rpx 0; border-block: 1rpx solid var(--divider); }
.order-detail view { display: flex; justify-content: space-between; gap: 8rpx; color: var(--text-muted); font-size: 21rpx; }
.order-detail view text:last-child { color: var(--text-primary); font-weight: 800; }
.pickup-code { margin-top: 18rpx; padding: 20rpx; text-align: center; background: var(--primary-soft); }
.pickup-code > text { display: block; color: var(--text-muted); font-size: 20rpx; }
.pickup-code view { margin: 5rpx 0; color: var(--primary-dark); font-family: "Songti SC", "STSong", serif; font-size: 52rpx; font-weight: 700; letter-spacing: 0; }
.order-footer { margin-top: 18rpx; color: var(--text-muted); font-size: 21rpx; }
.order-footer button { margin: 0; padding: 10rpx 18rpx; border: 1rpx solid #d7a297; border-radius: 6rpx; color: #a43f31; background: #fff; font-size: 21rpx; line-height: 1.3; }
.order-footer button::after { border: none; }
.ledger-list { border-block: 1rpx solid var(--border); }
.ledger-row { display: grid; grid-template-columns: 58rpx 1fr auto; gap: 15rpx; align-items: center; padding: 23rpx 0; border-bottom: 1rpx solid var(--divider); }
.ledger-row:last-child { border-bottom: none; }
.ledger-icon { width: 58rpx; height: 58rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: var(--primary-soft); }
.ledger-icon.debit { background: var(--warning-light); }
.ledger-copy { min-width: 0; }
.ledger-copy text { display: block; overflow: hidden; font-size: 25rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }
.ledger-copy view { margin-top: 7rpx; color: var(--text-muted); font-size: 20rpx; }
.ledger-amount { min-width: 100rpx; text-align: right; }
.ledger-amount text { font-size: 31rpx; font-weight: 850; }
.ledger-amount view { margin-top: 5rpx; color: var(--text-hint); font-size: 19rpx; }
.ledger-amount.positive text { color: var(--primary); }
.ledger-amount.negative text { color: var(--warning); }
