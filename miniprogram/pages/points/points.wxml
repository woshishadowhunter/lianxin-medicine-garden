<view class="points-page">
  <block wx:if="{{loading && !catalog.length}}">
    <view class="container"><loading-card rows="{{4}}" showAvatar="{{false}}" /></view>
  </block>

  <block wx:else>
    <view class="points-hero">
      <view class="hero-copy">
        <view class="points-bank-label"><lx-icon name="medal" size="{{23}}" tone="accent" /><text>连心成长积分</text></view>
        <view class="balance-line"><text class="points-balance">{{account.balance || 0}}</text><text class="points-unit">分可用</text></view>
        <text class="hero-note">记录成长，也让每一份认真及时兑现</text>
      </view>
      <view class="account-seal"><text>{{familyCode}}</text><view>家庭账户</view></view>
    </view>

    <view class="container points-content">
      <view class="points-summary">
        <view><text>{{account.total_earned || 0}}</text><view>累计获得</view></view>
        <view><text>{{account.total_redeemed || 0}}</text><view>累计兑换</view></view>
        <view><text>{{redemptions.length || 0}}</text><view>兑换记录</view></view>
      </view>

      <view class="view-tabs">
        <view class="view-tab {{activeView === 'rewards' ? 'active' : ''}}" data-view="rewards" bindtap="switchView">兑换好物</view>
        <view class="view-tab {{activeView === 'orders' ? 'active' : ''}}" data-view="orders" bindtap="switchView">我的兑换</view>
        <view class="view-tab {{activeView === 'ledger' ? 'active' : ''}}" data-view="ledger" bindtap="switchView">积分明细</view>
      </view>

      <block wx:if="{{activeView === 'rewards'}}">
        <view class="section-heading"><view><text>把成长带回家</text><text>兑换后 7 天内完成备货</text></view><lx-icon name="medal" size="{{26}}" tone="accent" /></view>
        <view class="reward-grid">
          <view wx:for="{{catalog}}" wx:key="code" class="reward-card">
            <view class="reward-visual"><lx-icon name="{{item.icon}}" size="{{42}}" tone="brand" /></view>
            <text class="reward-name">{{item.name}}</text>
            <text class="reward-desc">{{item.description}}</text>
            <view class="reward-meta"><text>{{item.points}} 积分</text><text>库存 {{item.available}}</text></view>
            <button class="redeem-button" loading="{{actionLoading === item.code}}" disabled="{{!item.canRedeem || actionLoading}}" data-code="{{item.code}}" bindtap="redeem">
              {{item.available <= 0 ? '暂时缺货' : item.shortage > 0 ? '还差 ' + item.shortage + ' 分' : '立即兑换'}}
            </button>
          </view>
        </view>
        <view class="service-note"><lx-icon name="clock" size="{{21}}" tone="muted" /><text>管理员备货后会更新为“待领取”，现场出示四位领取码即可领取。</text></view>
      </block>

      <block wx:elif="{{activeView === 'orders'}}">
        <view class="section-heading"><view><text>兑换进度</text><text>从申请到发放全程可追踪</text></view><text>{{redemptions.length}} 笔</text></view>
        <view wx:if="{{redemptions.length}}" class="order-list">
          <view wx:for="{{redemptions}}" wx:key="redemption_no" class="order-card">
            <view class="order-top"><view><text class="order-name">{{item.reward_name}}</text><text class="order-date">申请于 {{item.createdText}}</text></view><text class="status-tag {{item.tone}}">{{item.label}}</text></view>
            <view class="order-detail"><view><text>使用积分</text><text>{{item.points_cost}}</text></view><view><text>最晚备货</text><text>{{item.dueText}}</text></view></view>
            <view wx:if="{{item.status === 'ready'}}" class="pickup-code"><text>领取码</text><view>{{item.pickup_code}}</view><text>领取时向管理员出示</text></view>
            <view class="order-footer"><text>{{item.actionText}}</text><button wx:if="{{item.status === 'pending'}}" loading="{{actionLoading === item.redemption_no}}" disabled="{{actionLoading}}" data-id="{{item.redemption_no}}" bindtap="cancelRedemption">取消并退分</button></view>
          </view>
        </view>
        <empty-state wx:else iconName="medal" text="还没有兑换记录，去看看有哪些成长好物吧" />
      </block>

      <block wx:else>
        <view class="section-heading"><view><text>积分明细</text><text>每一笔获得、兑换和退款都有记录</text></view></view>
        <view wx:if="{{transactions.length}}" class="ledger-list">
          <view wx:for="{{transactions}}" wx:key="transaction_no" class="ledger-row">
            <view class="ledger-icon {{item.amount > 0 ? 'credit' : 'debit'}}"><lx-icon name="{{item.type === 'redemption' ? 'medal' : item.type === 'redemption_refund' ? 'sync' : item.type === 'reward' ? 'star' : 'check'}}" size="{{23}}" tone="{{item.amount > 0 ? 'brand' : 'warning'}}" /></view>
            <view class="ledger-copy"><text>{{item.description}}</text><view>{{item.typeLabel}} · {{item.createdText}}</view></view>
            <view class="ledger-amount {{item.amount > 0 ? 'positive' : 'negative'}}"><text>{{item.amountText}}</text><view>余额 {{item.balance_after}}</view></view>
          </view>
        </view>
        <empty-state wx:else iconName="archive" text="暂无积分明细，养护记录审核通过后会自动入账" />
      </block>
    </view>
  </block>
</view>
