.admin-points-page { padding-bottom: 70rpx; }
.admin-banner { margin-bottom: 24rpx; padding: 28rpx 24rpx; border-radius: 14rpx; color: #fff; background: var(--primary-dark); }
.admin-title { display: flex; align-items: center; gap: 10rpx; font-size: 30rpx; font-weight: 800; }
.nav-tab { color: rgba(255,255,255,.76); font-size: 23rpx; font-weight: 700; }
.bank-summary { display: grid; grid-template-columns: repeat(3, 1fr); border-block: 1rpx solid var(--border); }
.bank-summary > view { padding: 28rpx 6rpx; text-align: center; border-right: 1rpx solid var(--border); }
.bank-summary > view:last-child { border-right: none; }
.bank-summary text { font-family: "Songti SC", "STSong", serif; font-size: 40rpx; font-weight: 700; color: var(--primary-dark); }
.bank-summary view view { margin-top: 8rpx; color: var(--text-muted); font-size: 21rpx; }
.backfill-banner { display: grid; grid-template-columns: 1fr auto; gap: 18rpx; align-items: center; margin-top: 20rpx; padding: 20rpx 22rpx; border: 1rpx solid rgba(216,146,47,.25); border-radius: 12rpx; background: var(--warning-light); }
.backfill-banner text { display: block; color: #7c4a0a; font-size: 25rpx; font-weight: 800; }
.backfill-banner view view { margin-top: 5rpx; color: #8c631f; font-size: 21rpx; line-height: 1.45; }
.backfill-banner button { min-width: 142rpx; min-height: 66rpx; margin: 0; padding: 0 18rpx; border-radius: 10rpx; color: #fff; background: var(--warning); font-size: 23rpx; font-weight: 800; }
.issue-panel { padding: 26rpx; }
.form-field { margin-bottom: 24rpx; }
.field-label { display: block; margin-bottom: 11rpx; color: var(--text-secondary); font-size: 24rpx; font-weight: 800; }
.picker-value { min-height: 78rpx; padding: 0 20rpx; border: 1rpx solid var(--border); border-radius: 12rpx; background: var(--surface-2); display: flex; align-items: center; justify-content: space-between; font-size: 26rpx; }
.reward-note { width: 100%; min-height: 138rpx; padding: 18rpx 20rpx; border: 1rpx solid var(--border); border-radius: 12rpx; background: var(--surface-2); font-size: 26rpx; line-height: 1.5; }
.account-search { height: 72rpx; margin-bottom: 14rpx; padding: 0 20rpx; border: 1rpx solid var(--border); border-radius: 12rpx; background: var(--bg-card); display: flex; align-items: center; gap: 12rpx; }
.account-search input { flex: 1; font-size: 25rpx; }
.account-table, .recent-ledger { padding: 0 22rpx; border: 1rpx solid var(--border); border-radius: var(--radius); background: var(--bg-card); }
.account-row { display: grid; grid-template-columns: 1fr auto 110rpx; gap: 18rpx; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--divider); }
.account-row:last-child, .recent-row:last-child { border-bottom: none; }
.account-code { display: block; font-size: 26rpx; font-weight: 800; }.account-community { display: block; margin-top: 5rpx; color: var(--text-muted); font-size: 21rpx; }
.account-earned { color: var(--text-muted); font-size: 21rpx; }.account-balance { text-align: right; color: var(--primary-dark); font-family: "Songti SC", "STSong", serif; font-size: 32rpx; font-weight: 700; }.account-balance text { margin-left: 4rpx; font-family: inherit; font-size: 20rpx; font-weight: 400; }
.recent-row { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 22rpx 0; border-bottom: 1rpx solid var(--divider); }
.recent-title { display: block; font-size: 24rpx; font-weight: 700; }.recent-meta { display: block; margin-top: 6rpx; color: var(--text-muted); font-size: 20rpx; }.recent-amount { flex-shrink: 0; font-family: "Songti SC", "STSong", serif; font-size: 30rpx; font-weight: 700; }.recent-amount.positive { color: var(--primary); }.recent-amount.negative { color: var(--warning); }
