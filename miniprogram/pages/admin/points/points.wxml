<view class="container admin-points-page">
  <view class="admin-banner">
    <view class="flex-between">
      <view class="admin-title"><lx-icon name="medal" size="{{28}}" tone="white" /><text>积分兑现台</text></view>
      <text class="nav-tab" bindtap="goDashboard" hover-class="tap-chip">返回总览</text>
    </view>
    <text class="admin-subtitle">先处理超期，再备货，现场核码后完成发放</text>
  </view>

  <block wx:if="{{loading}}"><loading-card rows="{{5}}" showAvatar="{{false}}" /></block>
  <block wx:else>
    <view class="work-summary">
      <view class="summary-item urgent"><text>{{summary.fulfillment_overdue}}</text><view>已超期</view></view>
      <view class="summary-item"><text>{{summary.fulfillment_pending}}</text><view>待备货</view></view>
      <view class="summary-item"><text>{{summary.fulfillment_ready}}</text><view>待领取</view></view>
      <view class="summary-item"><text>{{summary.total_redeemed}}</text><view>已兑积分</view></view>
    </view>

    <view wx:if="{{summary.backfill_pending > 0}}" class="backfill-banner">
      <view><text>历史积分待补发</text><view>还有 {{summary.backfill_pending}} 条已确认记录未入账，每次安全处理 20 条。</view></view>
      <button loading="{{issuing}}" disabled="{{issuing}}" bindtap="backfillConfirmed">补发一批</button>
    </view>

    <view class="section-title"><text>发放工作队列</text><text>{{filteredRedemptions.length}} 笔</text></view>
    <view class="queue-tabs">
      <view class="{{fulfillmentFilter === 'overdue' ? 'active alert' : ''}}" data-status="overdue" bindtap="switchFulfillmentFilter">超期 {{summary.fulfillment_overdue}}</view>
      <view class="{{fulfillmentFilter === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="switchFulfillmentFilter">待备货 {{summary.fulfillment_pending}}</view>
      <view class="{{fulfillmentFilter === 'ready' ? 'active' : ''}}" data-status="ready" bindtap="switchFulfillmentFilter">待领取 {{summary.fulfillment_ready}}</view>
      <view class="{{fulfillmentFilter === 'fulfilled' ? 'active' : ''}}" data-status="fulfilled" bindtap="switchFulfillmentFilter">已完成</view>
    </view>

    <view wx:if="{{filteredRedemptions.length}}" class="fulfillment-list">
      <view wx:for="{{filteredRedemptions}}" wx:key="redemption_no" class="fulfillment-row {{item.overdue ? 'overdue' : ''}}">
        <view class="fulfillment-head">
          <view><text class="family-code">{{item.family_code}}</text><text class="reward-name">{{item.reward_name}}</text></view>
          <text class="queue-status">{{item.statusLabel}}</text>
        </view>
        <view class="fulfillment-meta">
          <text>领取码 {{item.pickup_code}}</text>
          <text>{{item.points_cost}} 积分</text>
          <text class="{{item.overdue ? 'danger-text' : ''}}">最晚 {{item.dueText}}</text>
        </view>
        <view class="fulfillment-actions">
          <text>申请 {{item.createdText}}</text>
          <view>
            <button wx:if="{{item.status === 'pending' || item.status === 'ready'}}" class="cancel-action" loading="{{fulfillmentLoading === item.redemption_no}}" disabled="{{fulfillmentLoading}}" data-id="{{item.redemption_no}}" data-status="canceled" bindtap="updateFulfillment">取消</button>
            <button wx:if="{{item.nextStatus}}" class="primary-action" loading="{{fulfillmentLoading === item.redemption_no}}" disabled="{{fulfillmentLoading}}" data-id="{{item.redemption_no}}" data-status="{{item.nextStatus}}" bindtap="updateFulfillment">{{item.nextLabel}}</button>
          </view>
        </view>
      </view>
    </view>
    <empty-state wx:else iconName="check" text="这个队列已经处理完毕" />
    <button wx:if="{{filteredRedemptions.length && queueHasMore}}" class="queue-more" loading="{{queueLoading}}" disabled="{{queueLoading}}" bindtap="loadMoreFulfillment">加载更多兑换单</button>

    <view class="section-title"><text>礼品库存</text><text>可用 / 预留 / 已发</text></view>
    <view class="stock-table">
      <view wx:for="{{catalog}}" wx:key="code" class="stock-row">
        <view class="stock-icon"><lx-icon name="{{item.icon}}" size="{{25}}" tone="brand" /></view>
        <view class="stock-copy"><text>{{item.name}}</text><view>{{item.points}} 分 · 可用 {{item.available}} · 预留 {{item.reserved}} · 已发 {{item.fulfilled}}</view></view>
        <view class="stock-actions">
          <button loading="{{stockLoading === item.code}}" disabled="{{stockLoading || item.available < 1}}" data-code="{{item.code}}" data-delta="-1" bindtap="adjustStock">−1</button>
          <button loading="{{stockLoading === item.code}}" disabled="{{stockLoading}}" data-code="{{item.code}}" data-delta="10" bindtap="adjustStock">+10</button>
        </view>
      </view>
    </view>

    <view class="section-title"><text>发放成长奖励</text><text>直接增加家庭积分</text></view>
    <view class="issue-panel panel">
      <view class="form-field">
        <text class="field-label">家庭账户</text>
        <picker mode="selector" range="{{familyLabels}}" value="{{selectedFamilyIndex}}" bindchange="onFamilyChange">
          <view class="picker-value">{{familyLabels[selectedFamilyIndex] || '请选择家庭'}}<lx-icon name="chevron-down" size="{{20}}" tone="muted" /></view>
        </picker>
      </view>
      <view class="form-field">
        <text class="field-label">奖励类型</text>
        <picker mode="selector" range="{{rewardLabels}}" value="{{selectedRewardIndex}}" bindchange="onRewardChange">
          <view class="picker-value">{{rewardLabels[selectedRewardIndex] || '请选择奖励'}}<lx-icon name="chevron-down" size="{{20}}" tone="muted" /></view>
        </picker>
      </view>
      <view class="form-field"><text class="field-label">奖励说明（可选）</text><textarea class="reward-note" maxlength="120" value="{{note}}" placeholder="例如：番茄成长档案完整，观察连续" bindinput="onNoteInput"></textarea></view>
      <button class="btn btn-primary" loading="{{issuing}}" disabled="{{issuing}}" bindtap="issueReward">{{issuing ? '正在入账...' : '确认发放积分'}}</button>
    </view>

    <view class="section-title"><text>家庭账户</text><text>{{accounts.length}} 户</text></view>
    <view class="account-search"><lx-icon name="search" size="{{22}}" tone="muted" /><input placeholder="搜索家庭编号或社区" bindinput="onSearchInput" /></view>
    <view class="account-table">
      <view wx:for="{{filteredAccounts}}" wx:key="family_code" class="account-row">
        <view><text class="account-code">{{item.family_code}}</text><text class="account-community">{{item.community}}</text></view>
        <view class="account-earned">已兑 {{item.total_redeemed}}</view>
        <view class="account-balance">{{item.balance}}<text>分</text></view>
      </view>
    </view>

    <view class="section-title"><text>最近积分流水</text><text>最新 30 笔</text></view>
    <view wx:if="{{recent.length}}" class="recent-ledger">
      <view wx:for="{{recent}}" wx:key="transaction_no" class="recent-row">
        <view><text class="recent-title">{{item.family_code}} · {{item.description}}</text><text class="recent-meta">{{item.createdText}} · 余额 {{item.balance_after}}</text></view>
        <text class="recent-amount {{item.amount > 0 ? 'positive' : 'negative'}}">{{item.amountText}}</text>
      </view>
    </view>
    <empty-state wx:else iconName="archive" text="暂无积分流水" />
  </block>
</view>
