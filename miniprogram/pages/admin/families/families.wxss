.filter-bar {
  margin-bottom: 24rpx;
}

.search-box {
  padding: 8rpx 24rpx;
}

.search-input {
  min-height: 58rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.filter-row {
  gap: 16rpx;
}

.filter-chip {
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(31, 107, 75, 0.12);
  border-radius: 999rpx;
  background: #fff;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.filter-count {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--text-hint);
}

.family-card {
  margin-bottom: 16rpx;
}

.family-card:active {
  transform: translateY(1rpx);
  opacity: 0.9;
}

.family-rank {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.family-rank.active {
  background: var(--primary-soft);
}

.rank-icon {
  font-size: 34rpx;
}

.ml-16 {
  margin-left: 16rpx;
}

.family-code {
  font-size: 31rpx;
  font-weight: 800;
}

.family-community {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

.family-status {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 800;
}

.family-stats {
  padding-top: 18rpx;
  border-top: 1rpx solid var(--divider);
}

.fstat {
  flex: 1;
  text-align: center;
}

.fstat-val {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.fstat-label {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--text-hint);
}
