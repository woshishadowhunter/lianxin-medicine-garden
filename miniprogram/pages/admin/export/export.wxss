.page-header {
  margin-bottom: 24rpx;
  padding: 30rpx 0 10rpx;
}

.page-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.page-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text-secondary);
}

.export-type-card {
  margin-bottom: 14rpx;
  padding: 24rpx;
}

.export-type-card.selected {
  border-color: rgba(31, 107, 75, 0.34);
  background: var(--primary-soft);
  box-shadow: none;
}

.export-type-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
  border-radius: 16rpx;
  background: var(--accent-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.export-type-label {
  font-size: 29rpx;
  font-weight: 800;
}

.export-type-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-hint);
}

.date-row {
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: var(--radius);
  background: var(--primary-soft);
  text-align: center;
  font-size: 27rpx;
  font-weight: 700;
  color: var(--primary);
}

.date-sep {
  font-size: 28rpx;
  color: var(--text-hint);
}

.date-hint {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

.result-icon {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 800;
}

.result-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

.result-error {
  font-size: 27rpx;
  line-height: 1.5;
  color: var(--danger);
}
