.admin-page {
  padding-top: 0;
}

.admin-top {
  margin: 0 -24rpx 24rpx;
  padding: 34rpx 24rpx 24rpx;
  color: #fff;
  background: var(--primary-dark);
}

.admin-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 33rpx;
  font-weight: 900;
}

.admin-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.admin-tab {
  height: 60rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 850;
}

.admin-tab.active {
  color: var(--primary-dark);
  background: #fff;
}

.audit-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.audit-stat {
  margin-bottom: 0;
  padding: 22rpx 12rpx;
}

.audit-stat-num {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.audit-stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.filter-section {
  position: sticky;
  top: 0;
  z-index: 10;
  margin: 0 -24rpx 22rpx;
  padding: 14rpx 24rpx 18rpx;
  background: rgba(238, 242, 237, 0.96);
}

.filter-tabs {
  gap: 0;
  padding: 6rpx;
  border: 1rpx solid rgba(31, 107, 75, 0.09);
  border-radius: 999rpx;
  background: #fff;
  box-shadow: none;
}

.filter-tab {
  flex: 1;
  min-height: 54rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 850;
  color: var(--text-muted);
}

.filter-tab.active {
  color: #fff;
  background: var(--primary);
}

.filter-extra {
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-chip {
  min-height: 54rpx;
  padding: 0 18rpx;
  border: 1rpx solid var(--border);
  border-radius: 999rpx;
  background: #fff;
  font-size: 22rpx;
  font-weight: 850;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.filter-chip.active {
  color: #fff;
  border-color: var(--primary);
  background: var(--primary);
}

.select-all {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 850;
  color: var(--primary);
}

.batch-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.batch-actions .btn {
  min-height: 54rpx;
  padding: 0 18rpx;
  font-size: 22rpx;
}

.audit-card {
  margin-bottom: 16rpx;
  padding: 18rpx;
}

.audit-row {
  display: grid;
  grid-template-columns: 38rpx 124rpx 1fr;
  gap: 18rpx;
  align-items: flex-start;
}

.audit-check {
  margin-top: 8rpx;
}

.audit-photo {
  position: relative;
  overflow: hidden;
  width: 124rpx;
  height: 124rpx;
  border-radius: 14rpx;
  background: var(--bg-deep);
}

.audit-photo image {
  width: 100%;
  height: 100%;
  display: block;
}

.audit-photo text {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  min-height: 32rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  color: #fff;
  background: rgba(18, 60, 45, 0.72);
  font-size: 19rpx;
  font-weight: 850;
  line-height: 32rpx;
}

.audit-photo.empty {
  display: flex;
  align-items: center;
  justify-content: center;
}

.audit-main {
  min-width: 0;
}

.audit-head {
  gap: 10rpx;
}

.audit-family {
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
  color: var(--text-primary);
}

.audit-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.35;
  color: var(--text-muted);
}

.audit-summary-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.audit-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.small-btn {
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  color: #fff;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 850;
}

.small-btn.ghost {
  color: var(--danger);
  background: var(--danger-light);
}

.audit-detail {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--divider);
}

.detail-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.detail-photo {
  width: calc(25% - 6rpx);
  height: 142rpx;
  border-radius: 10rpx;
  background: var(--bg-deep);
}

.detail-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.detail-label {
  font-weight: 900;
  color: var(--text-primary);
}

.detail-meta-row {
  gap: 16rpx;
  flex-wrap: wrap;
  font-size: 22rpx;
  color: var(--text-hint);
}

.meta-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.audit-comment {
  padding: 14rpx 18rpx;
  border-radius: var(--radius);
  background: var(--warning-light);
  font-size: 24rpx;
}
