.admin-banner {
  margin-bottom: 24rpx;
  padding: 30rpx 24rpx;
  border-radius: 14rpx;
  background: var(--primary-dark);
  box-shadow: var(--shadow-soft);
}

.admin-title {
  color: #fff;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.nav-tabs {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.nav-tab {
  min-height: 50rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.nav-tab.active {
  color: var(--primary-dark);
  background: #fff;
}

.nav-tab.exit {
  color: rgba(255, 255, 255, 0.56);
}

.chart-card {
  margin-bottom: 24rpx;
}

.chart-card .card-title {
  margin-bottom: 0;
}

.chart-row {
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.chart-half {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.chart-half .card-title {
  font-size: 28rpx;
}

.chart-empty,
.chart-empty-sm {
  padding: 82rpx 0;
  text-align: center;
  color: var(--text-hint);
  font-size: 26rpx;
}

.chart-empty-sm {
  padding: 100rpx 0;
  font-size: 24rpx;
}
