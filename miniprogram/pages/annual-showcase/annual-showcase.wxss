.annual-header {
  margin-bottom: 24rpx;
  padding: 46rpx 24rpx;
  text-align: center;
  color: #fff;
  background: var(--primary-dark);
}

.annual-year {
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1;
  color: #fff;
}

.annual-title {
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.annual-community {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.76);
}

.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.badge-item {
  width: calc(50% - 6rpx);
  min-height: 112rpx;
  padding: 16rpx;
  border-radius: var(--radius);
  background: var(--accent-light);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.badge-icon {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
  background: rgba(185, 139, 69, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.badge-label {
  display: block;
  font-size: 23rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.badge-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 19rpx;
  line-height: 1.35;
  color: var(--text-hint);
}

.herb-showcase {
  margin-bottom: 22rpx;
}

.showcase-icon {
  width: 78rpx;
  height: 78rpx;
  margin-right: 18rpx;
  border-radius: 16rpx;
  background: var(--primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.showcase-name {
  font-size: 31rpx;
  font-weight: 800;
}

.showcase-status {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.showcase-stats {
  flex-shrink: 0;
  display: flex;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

.compare-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.compare-photos {
  gap: 12rpx;
}

.compare-item {
  flex: 1;
  min-width: 0;
}

.compare-img {
  width: 100%;
  height: 204rpx;
  border-radius: 12rpx;
  background: var(--bg-deep);
}

.compare-tag {
  display: block;
  margin-top: 6rpx;
  text-align: center;
  font-size: 20rpx;
  color: var(--text-hint);
}

.compare-arrow {
  flex-shrink: 0;
  align-self: center;
  font-size: 34rpx;
  color: var(--accent);
}

.care-type-mini {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.type-mini-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  font-size: 18rpx;
  font-weight: 700;
  color: var(--primary);
}
